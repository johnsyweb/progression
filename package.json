{
  "name": "progress",
  "version": "1.0.0",
  "description": "Progress bar microsite for www.johnsy.com",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\"",
    "typecheck": "tsc --noEmit",
    "precommit": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test:run",
    "prepare": "husky",
    "lighthouse": "tsx scripts/run-lighthouse.ts",
    "generate:screenshot:build": "tsc --ignoreConfig --ignoreDeprecations 6.0 --types node scripts/generate-readme-screenshot.ts --outDir scripts --esModuleInterop --skipLibCheck --module es2020 --target es2020 --moduleResolution node",
    "generate:screenshot": "pnpm run generate:screenshot:build && node scripts/generate-readme-screenshot.js",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "setup:branch-protection": "bash scripts/apply-branch-protection.sh"
  },
  "keywords": [],
  "author": "Pete Johns",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.5",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "html2canvas": "^1.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.26.0"
}
